# BGE-M3 embed server image (compose `bge` profile).
# CPU-only by default; GPU users typically run the server on the host instead
# (pip install -e .[bge-local] && python -m hippocampus.embed.server).
FROM python:3.12-slim

WORKDIR /app
COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --no-cache-dir ".[bge-local,web]"

EXPOSE 8086
CMD ["python", "-m", "hippocampus.embed.server"]
